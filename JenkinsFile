pipeline {
    agent any

    stages {
      
        
        stage('restore apphost'){
            steps{
                bat 'dotnet restore MicroServicesProject/AspireHostSolution/AspireHostSolution.slnx'
                    echo 'Restore completed successfully.'
            }
        }

        stage('build apphost'){
            steps{
                bat 'dotnet build MicroServicesProject/AspireHostSolution/AspireHostSolution.slnx --configuration Release --no-restore'
                 echo 'Build completed successfully.'
            }
        }
        
        stage('run apphost'){
            steps{
                bat 'dotnet run --project MicroServicesProject/AspireHostSolution/AspireHostSolution.AppHost/AspireHostSolution.AppHost.csproj'
                 echo 'Run completed successfully.'
            }
        }
    }


}